@startuml C1-LEGO-Inventory-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()
HIDE_STEREOTYPE()

skinparam defaultFontName "Arial"
skinparam shadowing false

skinparam rectangle {
    BorderColor #7a7a7a
    FontColor #222
    BackgroundColor #7f7f7f
}

skinparam package {
    BackgroundColor #ffffff
    BorderColor #7a7a7a
}

skinparam arrow {
    ArrowColor #9aa0a6
    ArrowThickness 1.5
}

' Custom element tags
AddElementTag("brand", $bgColor="#4285f4", $fontColor="#ffffff", $borderColor="#1a73e8")
AddElementTag("neutral", $bgColor="#7f7f7f", $fontColor="#ffffff", $borderColor="#7a7a7a")
AddElementTag("infra", $bgColor="#34a853", $fontColor="#ffffff", $borderColor="#137333")

Person(user, "LEGO Collector", "Manages LEGO parts and sets inventory")

System(lego_inventory, "LEGO Inventory Management System", "Manages inventory of LEGO parts and sets, tracks locations, and provides reconciliation tools")

System_Ext(rebrickable, "Rebrickable API", "External API providing canonical LEGO part, color, and set data")

System_Ext(instabrick, "Instabrick/BrickLink", "XML export files for importing existing inventory")

Rel(user, lego_inventory, "Manages inventory, views reports, reconciles locations", "HTTPS")
Rel(lego_inventory, rebrickable, "Fetches part metadata, colors, set information", "HTTPS")
Rel(instabrick, lego_inventory, "Imports inventory data", "XML files")

SHOW_LEGEND()

@enduml

